{
  "name": "pi-goal",
  "version": "0.1.0",
  "description": "Pi extension that keeps a session working until a transcript-evaluated goal is met.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "goal"
  ],
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "test:pack": "npm pack --dry-run --json",
    "validate": "npm run typecheck && npm test && npm run test:pack"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
